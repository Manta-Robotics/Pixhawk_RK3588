[Unit]
Description=Manta MAVLink Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__PROJECT_DIR__
ExecStart=/usr/bin/python3 __PROJECT_DIR__/backend/mavlink_bridge.py
Restart=always
RestartSec=2
StandardOutput=append:__PROJECT_DIR__/logs/mavlink.log
StandardError=append:__PROJECT_DIR__/logs/mavlink.log

[Install]
WantedBy=multi-user.target
