[Unit]
Description=Manta Dashboard Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__PROJECT_DIR__
ExecStart=/bin/bash __PROJECT_DIR__/scripts/systemd_backend.sh
Restart=always
RestartSec=2
StandardOutput=append:__PROJECT_DIR__/logs/server.log
StandardError=append:__PROJECT_DIR__/logs/server.log

[Install]
WantedBy=multi-user.target
